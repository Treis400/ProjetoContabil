  accumDeprecAccountCode String?
  deprecExpenseAccountCode String?
  active                Boolean              @default(true)
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  client                Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent                PatrimonyGroup?      @relation("GroupParent", fields: [parentId], references: [id])
  children              PatrimonyGroup[]     @relation("GroupParent")
  assets                PatrimonyAsset[]

  @@unique([clientId, code])
}

model PatrimonyLocation {
  id        String   @id @default(cuid())
  clientId  String
  code      String
  name      String
  type      String?
  parentId  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent    PatrimonyLocation? @relation("LocationParent", fields: [parentId], references: [id])
  children  PatrimonyLocation[] @relation("LocationParent")
  assets    PatrimonyAsset[]

  @@unique([clientId, code])
}

model PatrimonyResponsible {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  role      String?
  sector    String?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assets    PatrimonyAsset[]
}

model PatrimonyAsset {
  id                   String                  @id @default(cuid())
  clientId             String
  tombamento           String
  internalCode         String?
  description          String
  serialNumber         String?
  brand                String?
  model                String?
  manufacturer         String?
  barcode              String?

  groupId              String?
  locationId           String?
  responsibleId        String?
  costCenterCode       String?

  acquisitionType      PatrimonyAcquisitionType @default(COMPRA)
  acquisitionDate      DateTime
  acquisitionValue     Decimal                  @db.Decimal(14, 2)
  residualValue        Decimal                  @default(0) @db.Decimal(14, 2)
  usefulLifeMonths     Int                      @default(60)
  usefulLifeMonthsFiscal Int                    @default(60)
  deprecMethod         PatrimonyDeprecMethod    @default(LINEAR)
  deprecStartDate      DateTime?
  deprecSuspended      Boolean                  @default(false)

  documentOrigin       String?

  status               PatrimonyAssetStatus     @default(ATIVO)

  assetAccountCode     String?
  accumDeprecAccountCode String?
  deprecExpenseAccountCode String?

  technicalNotes       String?
  oldTombamento        String?

  active               Boolean                  @default(true)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  client               Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  group                PatrimonyGroup?           @relation(fields: [groupId], references: [id])
  location             PatrimonyLocation?        @relation(fields: [locationId], references: [id])
  responsible          PatrimonyResponsible?     @relation(fields: [responsibleId], references: [id])
  depreciations        PatrimonyDepreciation[]
  movements            PatrimonyMovement[]
  revaluations         PatrimonyRevaluation[]
  disposals            PatrimonyDisposal[]
  inventoryItems       PatrimonyInventoryItem[]

  @@unique([clientId, tombamento])
  @@index([clientId, groupId])
  @@index([clientId, status])
}

model PatrimonyDepreciation {
  id               String         @id @default(cuid())
  assetId          String
  periodMonth      Int
  periodYear       Int
  openingValue     Decimal        @db.Decimal(14, 2)
  accumDeprecOpen  Decimal        @default(0) @db.Decimal(14, 2)
  monthlyDeprec    Decimal        @default(0) @db.Decimal(14, 2)
  accumDeprecClose Decimal        @default(0) @db.Decimal(14, 2)
  closingValue     Decimal        @db.Decimal(14, 2)
  fiscalDeprec     Decimal        @default(0) @db.Decimal(14, 2)
  entryRef         String?
  createdAt        DateTime       @default(now())

  asset            PatrimonyAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, periodYear, periodMonth])
  @@index([assetId])
}

model PatrimonyMovement {
  id                String                @id @default(cuid())
  assetId           String
  type              PatrimonyMovementType
  movementDate      DateTime
  fromLocationId    String?
  toLocationId      String?
  fromResponsibleId String?
  toResponsibleId   String?
  fromStatus        PatrimonyAssetStatus?
  toStatus          PatrimonyAssetStatus?
  reason            String?
  document          String?
  notes             String?
  createdAt         DateTime              @default(now())

  asset             PatrimonyAsset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model PatrimonyRevaluation {
  id              String                   @id @default(cuid())
  assetId         String
  type            PatrimonyRevaluationType @default(REAVALIACAO)
  revaluationDate DateTime
  previousValue   Decimal                  @db.Decimal(14, 2)
  newValue        Decimal                  @db.Decimal(14, 2)
  adjustment      Decimal                  @db.Decimal(14, 2)
  expertReport    String?
  accountCode     String?
  entryRef        String?
  notes           String?
  createdAt       DateTime                 @default(now())

  asset           PatrimonyAsset           @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model PatrimonyDisposal {
  id               String                @id @default(cuid())
  assetId          String
  type             PatrimonyDisposalType @default(SUCATEAMENTO)
  disposalDate     DateTime
  bookValue        Decimal               @db.Decimal(14, 2)
  saleValue        Decimal               @default(0) @db.Decimal(14, 2)
  gainLoss         Decimal               @default(0) @db.Decimal(14, 2)
  finalDeprec      Decimal               @default(0) @db.Decimal(14, 2)
  documentRef      String?
  entryRef         String?
  notes            String?
  createdAt        DateTime              @default(now())

  asset            PatrimonyAsset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model PatrimonyInventory {
  id          String                    @id @default(cuid())
  clientId    String
  name        String
  startDate   DateTime
  endDate     DateTime?
  status      PatrimonyInventoryStatus  @default(ABERTO)
  notes       String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  client      Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items       PatrimonyInventoryItem[]

  @@index([clientId])
}

model PatrimonyInventoryItem {
  id            String             @id @default(cuid())
  inventoryId   String
  assetId       String
  found         Boolean?
  foundLocation String?
  foundCondition String?
  notes         String?
  checkedAt     DateTime?

  inventory     PatrimonyInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  asset         PatrimonyAsset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([inventoryId, assetId])
}
