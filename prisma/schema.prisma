model FiscalObligation {
  id           String            @id @default(cuid())
  clientId     String
  type         ObligationType
  periodMonth  Int
  periodYear   Int
  dueDate      DateTime?
  status       ObligationStatus  @default(PENDENTE)
  notes        String?
  fileContent  String?           @db.Text
  fileName     String?
  errorMessage String?
  generatedAt  DateTime?
  transmittedAt DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdById  String?
  client       Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy    User?             @relation("ObligationCreatedBy", fields: [createdById], references: [id])

  @@unique([clientId, type, periodMonth, periodYear])
  @@index([clientId, periodYear, periodMonth])
}

model FiscalBook {
  id             String    @id @default(cuid())
  clientId       String
  bookType       BookType
  periodMonth    Int
  periodYear     Int
  generatedAt    DateTime  @default(now())
  totalEntries   Int       @default(0)
  totalSaidas    Int       @default(0)
  totalValueEntries Decimal @default(0) @db.Decimal(14, 2)
  totalValueSaidas  Decimal @default(0) @db.Decimal(14, 2)
  totalIcms      Decimal   @default(0) @db.Decimal(14, 2)
  totalIpi       Decimal   @default(0) @db.Decimal(14, 2)
  totalPis       Decimal   @default(0) @db.Decimal(14, 2)
  totalCofins    Decimal   @default(0) @db.Decimal(14, 2)
  totalIss       Decimal   @default(0) @db.Decimal(14, 2)
  fileContent    String?   @db.Text
  createdAt      DateTime  @default(now())
  createdById    String?
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy      User?     @relation("BookCreatedBy", fields: [createdById], references: [id])

  @@index([clientId, periodYear, periodMonth])
}

