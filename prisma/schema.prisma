generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  passwordHash     String
  role             UserRole          @default(EMPLOYEE)
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  alertsResolved   Alert[]           @relation("AlertResolvedBy")
  auditLogs        AuditLog[]
  createdClients   Client[]          @relation("ClientCreatedBy")
  updatedClients   Client[]          @relation("ClientUpdatedBy")
  clientChanges    ClientChangeLog[]
  documents        Document[]
  createdProcesses Process[]         @relation("ProcessCreatedBy")
  responsibleFor   Process[]         @relation("ProcessResponsible")
  updatedProcesses Process[]         @relation("ProcessUpdatedBy")
  processMoves     ProcessMovement[]
  stepsResponsible ProcessStep[]     @relation("StepResponsible")
  taxReviews       TaxAnnualReview[]
  fiscalDocuments  FiscalDocument[]   @relation("FiscalDocCreatedBy")
  taxApurations    TaxApuration[]     @relation("ApurationCreatedBy")
  fiscalObligations FiscalObligation[] @relation("ObligationCreatedBy")
  fiscalBooks      FiscalBook[]       @relation("BookCreatedBy")
  accountingEntries AccountingEntry[] @relation("EntryCreatedBy")
  lalurPeriodsLocked LalurPeriod[]   @relation("LalurPeriodLockedBy")
  lalurPartBMovements LalurPartBMovement[] @relation("LalurPartBMovCreatedBy")
  lalurImports     LalurAccountingImport[] @relation("LalurImportedBy")
  lalurAuditLogs   LalurAuditLog[]  @relation("LalurAuditLogUser")
}

model Client {
  id                     String             @id @default(cuid())
  companyName            String
  tradeName              String?
  cnpj                   String             @unique
  stateRegistration      String?
  municipalRegistration  String?
  mainCnae               String?
  taxRegime              String?
  openingDate            DateTime?
  companyStatus          CompanyStatus      @default(ATIVA)
  legalRepresentative    String?
  legalRepresentativeCpf String?
  phone                  String?
  whatsapp               String?
  email                  String?
  fullAddress            String?
  internalNotes          String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  createdById            String
  updatedById            String
  alerts                 Alert[]
  createdBy              User               @relation("ClientCreatedBy", fields: [createdById], references: [id])
  updatedBy              User               @relation("ClientUpdatedBy", fields: [updatedById], references: [id])
  changeLogs             ClientChangeLog[]
  monthlyFees            ClientMonthlyFee[]
  services               ClientService[]
  taxProfile             ClientTaxProfile?
  documents              Document[]
  processes              Process[]
  taxReviews             TaxAnnualReview[]
  fiscalProducts         FiscalProduct[]
  fiscalServices         FiscalService[]
  operationNatures       OperationNature[]
  fiscalDocuments        FiscalDocument[]
  taxApurations          TaxApuration[]
  fiscalObligations      FiscalObligation[]
  fiscalBooks            FiscalBook[]
  accountingPlans        AccountingPlan[]
  costCenters            CostCenter[]
  standardHistories      StandardHistory[]
  entryTypes             EntryType[]
  accountingParameters   AccountingParameters?
  accountingEntries      AccountingEntry[]
  periodClosings         PeriodClosing[]
  lalurAdjustTypes       LalurAdjustType[]
  lalurPeriods           LalurPeriod[]
  lalurAccountingRules   LalurAccountingRule[]
  lalurCompensations     LalurCompensation[]
  lalurAccountingImports LalurAccountingImport[]
  lalurAuditLogs         LalurAuditLog[]
  ecfFiles               EcfFile[]
  patrimonyGroups        PatrimonyGroup[]
  patrimonyLocations     PatrimonyLocation[]
  patrimonyResponsibles  PatrimonyResponsible[]
  patrimonyAssets        PatrimonyAsset[]
  patrimonyInventories   PatrimonyInventory[]
}

model ClientTaxProfile {
  id                       String            @id @default(cuid())
  clientId                 String            @unique
  companyType              CompanyType
  cityHall                 String?
  regulatoryAgency         String?
  digitalCertificate       String?
  digitalCertificateExpiry DateTime?
  currentTaxSituation      TaxReviewStatus?

  // ICMS
  icmsApurationType        IcmsApurationType?
  icmsHasSt                Boolean           @default(false)
  icmsHasDifal             Boolean           @default(false)
  icmsHasPartilha          Boolean           @default(false)

  // IPI
  ipiContributor           Boolean           @default(false)

  // PIS/COFINS
  pisCofinsRegime          PisCofinsRegime?

  // ISS
  issMainMunicipality      String?
  issHasRetention          Boolean           @default(false)

  // SPED
  spedFiscalPeriod         SpedPeriod?
  spedContribPeriod        SpedPeriod?

  // Certificado digital
  certificateType          CertificateType?
  certificateResponsible   String?

  client                   Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model FiscalProduct {
  id                       String    @id @default(cuid())
  clientId                 String
  internalCode             String
  description              String
  unitOfMeasure            String
  barcode                  String?
  ncm                      String
  cest                     String?
  group                    String?
  subgroup                 String?

  cfopInbound              String?
  cfopOutbound             String?

  cstIcms                  String?
  csosnIcms                String?
  cstIpi                   String?
  cstPisCofins             String?

  icmsInternalRate         Decimal?  @db.Decimal(7, 4)
  icmsInterstateRate       Decimal?  @db.Decimal(7, 4)
  icmsStRate               Decimal?  @db.Decimal(7, 4)
  ipiRate                  Decimal?  @db.Decimal(7, 4)
  pisRate                  Decimal?  @db.Decimal(7, 4)
  cofinsRate               Decimal?  @db.Decimal(7, 4)

  generatesPisCofinsCredit Boolean   @default(false)
  isMonophasic             Boolean   @default(false)
  isSubjectToSt            Boolean   @default(false)
  generatesDifal           Boolean   @default(false)
  isImported               Boolean   @default(false)
  isFuel                   Boolean   @default(false)
  isEnergy                 Boolean   @default(false)
  isCommunication          Boolean   @default(false)
  isTransport              Boolean   @default(false)
  isForConsumption         Boolean   @default(false)
  isForResale              Boolean   @default(false)
  isFixedAsset             Boolean   @default(false)

  active                   Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  client                   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, internalCode])
}

model FiscalService {
  id                       String    @id @default(cuid())
  clientId                 String
  internalCode             String
  description              String
  municipalCode            String?
  lc116Code                String?

  issRate                  Decimal?  @db.Decimal(7, 4)
  issOwnRule               Boolean   @default(false)
  issRetainedRule          Boolean   @default(false)
  issSubstituteRule        Boolean   @default(false)

  hasInssRetention         Boolean   @default(false)
  hasIrrfRetention         Boolean   @default(false)
  hasCsllRetention         Boolean   @default(false)
  hasPisRetention          Boolean   @default(false)
  hasCofinsRetention       Boolean   @default(false)

  isServiceExport          Boolean   @default(false)
  incidenceMunicipality    IssIncidenceMunicipality?

  active                   Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  client                   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, internalCode])
}

model CfopTable {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String
  operationType CfopOperationType
  creditImpact  String?
  active        Boolean  @default(true)
}

model CstTable {
  id          String      @id @default(cuid())
  code        String
  description String
  taxType     CstTaxType
  entryExit   CstEntryExit?
  active      Boolean     @default(true)

  @@unique([code, taxType])
}

model NcmTable {
  code        String    @id
  description String
  validFrom   DateTime?
  validUntil  DateTime?
}

model CestTable {
  code        String    @id
  ncm         String
  description String
  validFrom   DateTime?
  validUntil  DateTime?
}

model TaxApuration {
  id              String           @id @default(cuid())
  clientId        String
  taxType         TaxApurationType
  periodMonth     Int
  periodYear      Int
  status          ApurationStatus  @default(ABERTA)
  notes           String?
  calculatedAt    DateTime?
  closedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String?

  client          Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy       User?                        @relation("ApurationCreatedBy", fields: [createdById], references: [id])
  adjustments     TaxApurationAdjustment[]
  result          TaxApurationResult?
  simplesRevenues TaxApurationSimplesRevenue[]

  @@unique([clientId, taxType, periodMonth, periodYear])
  @@index([clientId, periodYear, periodMonth])
}

model TaxApurationAdjustment {
  id           String         @id @default(cuid())
  apurationId  String
  type         AdjustmentType
  description  String
  value        Decimal        @db.Decimal(14, 2)
  createdAt    DateTime       @default(now())

  apuration    TaxApuration   @relation(fields: [apurationId], references: [id], onDelete: Cascade)
}

model TaxApurationResult {
  id              String       @id @default(cuid())
  apurationId     String       @unique

  // ICMS / IPI (débitos, créditos, ST, DIFAL, ajustes, saldo)
  totalDebits     Decimal      @default(0) @db.Decimal(14, 2)
  totalCredits    Decimal      @default(0) @db.Decimal(14, 2)
  totalStDebits   Decimal      @default(0) @db.Decimal(14, 2)
  totalStCredits  Decimal      @default(0) @db.Decimal(14, 2)
  totalDifal      Decimal      @default(0) @db.Decimal(14, 2)
  totalPartilha   Decimal      @default(0) @db.Decimal(14, 2)
  totalAdjustments Decimal     @default(0) @db.Decimal(14, 2)
  previousBalance Decimal      @default(0) @db.Decimal(14, 2)
  balance         Decimal      @default(0) @db.Decimal(14, 2)
  taxDue          Decimal      @default(0) @db.Decimal(14, 2)
  nextBalance     Decimal      @default(0) @db.Decimal(14, 2)

  // PIS / COFINS
  pisRevenue      Decimal      @default(0) @db.Decimal(14, 2)
  pisDebits       Decimal      @default(0) @db.Decimal(14, 2)
  pisCredits      Decimal      @default(0) @db.Decimal(14, 2)
  pisNet          Decimal      @default(0) @db.Decimal(14, 2)
  cofinsRevenue   Decimal      @default(0) @db.Decimal(14, 2)
  cofinsDebits    Decimal      @default(0) @db.Decimal(14, 2)
  cofinsCredits   Decimal      @default(0) @db.Decimal(14, 2)
  cofinsNet       Decimal      @default(0) @db.Decimal(14, 2)

  // ISS
  issOwn          Decimal      @default(0) @db.Decimal(14, 2)
  issRetained     Decimal      @default(0) @db.Decimal(14, 2)
  issSubstitute   Decimal      @default(0) @db.Decimal(14, 2)
  issNet          Decimal      @default(0) @db.Decimal(14, 2)

  // Simples Nacional
  simplesRbcTotal Decimal      @default(0) @db.Decimal(14, 2)
  simplesRbcAcum  Decimal      @default(0) @db.Decimal(14, 2)
  simplesAliquota Decimal      @default(0) @db.Decimal(7, 4)
  simplesTotalDue Decimal      @default(0) @db.Decimal(14, 2)

  calculatedAt    DateTime     @default(now())

  apuration       TaxApuration @relation(fields: [apurationId], references: [id], onDelete: Cascade)
}

model TaxApurationSimplesRevenue {
  id                  String       @id @default(cuid())
  apurationId         String
  annex               String
  totalRevenue        Decimal      @default(0) @db.Decimal(14, 2)
  revenueWithSt       Decimal      @default(0) @db.Decimal(14, 2)
  revenueMonophasic   Decimal      @default(0) @db.Decimal(14, 2)
  revenueIssRetained  Decimal      @default(0) @db.Decimal(14, 2)
  netRevenue          Decimal      @default(0) @db.Decimal(14, 2)

  apuration           TaxApuration @relation(fields: [apurationId], references: [id], onDelete: Cascade)

  @@unique([apurationId, annex])
}

model OperationNature {
  id          String   @id @default(cuid())
  clientId    String?
  code        String
  description String
  cfop        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model FiscalDocument {
  id                   String               @id @default(cuid())
  clientId             String
  documentType         FiscalDocumentType
  entryExit            FiscalEntryExit
  status               FiscalDocumentStatus @default(REGULAR)
  origin               FiscalDocumentOrigin @default(DIGITACAO_MANUAL)

  // Identificação
  documentNumber       String
  series               String?
  accessKey            String?              @unique
  issueDate            DateTime
  entryExitDate        DateTime?

  // Emitente
  cnpjIssuer           String
  nameIssuer           String
  stateRegIssuer       String?
  ufIssuer             String?

  // Destinatário
  cnpjRecipient        String?
  nameRecipient        String?
  stateRegRecipient    String?
  ufRecipient          String?

  // Totais
  totalProducts        Decimal              @default(0) @db.Decimal(14, 2)
  totalDocument        Decimal              @default(0) @db.Decimal(14, 2)
  totalFreight         Decimal              @default(0) @db.Decimal(14, 2)
  totalInsurance       Decimal              @default(0) @db.Decimal(14, 2)
  totalDiscount        Decimal              @default(0) @db.Decimal(14, 2)
  totalOther           Decimal              @default(0) @db.Decimal(14, 2)

  // ICMS
  baseIcms             Decimal              @default(0) @db.Decimal(14, 2)
  valueIcms            Decimal              @default(0) @db.Decimal(14, 2)
  baseIcmsSt           Decimal              @default(0) @db.Decimal(14, 2)
  valueIcmsSt          Decimal              @default(0) @db.Decimal(14, 2)

  // IPI
  valueIpi             Decimal              @default(0) @db.Decimal(14, 2)

  // PIS / COFINS
  valuePis             Decimal              @default(0) @db.Decimal(14, 2)
  valueCofins          Decimal              @default(0) @db.Decimal(14, 2)

  // ISS (NFS-e)
  baseIss              Decimal              @default(0) @db.Decimal(14, 2)
  valueIss             Decimal              @default(0) @db.Decimal(14, 2)
  valueIssRetained     Decimal              @default(0) @db.Decimal(14, 2)

  // Retenções
  valueInss            Decimal              @default(0) @db.Decimal(14, 2)
  valueIrrf            Decimal              @default(0) @db.Decimal(14, 2)
  valueCsll            Decimal              @default(0) @db.Decimal(14, 2)

  // XML original
  xmlContent           String?

  // Validação
  validationStatus     ValidationStatus     @default(PENDENTE)
  validationErrors     Json?

  notes                String?
  periodMonth          Int?
  periodYear           Int?

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  createdById          String?

  client               Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy            User?                @relation("FiscalDocCreatedBy", fields: [createdById], references: [id])
  items                FiscalDocumentItem[]

  @@index([clientId, periodYear, periodMonth])
  @@index([clientId, entryExit])
  @@index([accessKey])
}

model FiscalDocumentItem {
  id              String          @id @default(cuid())
  documentId      String
  itemNumber      Int
  productCode     String?
  description     String
  ncm             String?
  cfop            String
  unitOfMeasure   String?

  quantity        Decimal         @db.Decimal(14, 4)
  unitValue       Decimal         @db.Decimal(14, 4)
  totalValue      Decimal         @db.Decimal(14, 2)
  discount        Decimal         @default(0) @db.Decimal(14, 2)

  // CST / CSOSN
  cstIcms         String?
  csosnIcms       String?
  cstIpi          String?
  cstPisCofins    String?

  // ICMS
  baseIcms        Decimal         @default(0) @db.Decimal(14, 2)
  icmsRate        Decimal         @default(0) @db.Decimal(7, 4)
  valueIcms       Decimal         @default(0) @db.Decimal(14, 2)

  // ICMS ST
  baseIcmsSt      Decimal         @default(0) @db.Decimal(14, 2)
  icmsStRate      Decimal         @default(0) @db.Decimal(7, 4)
  valueIcmsSt     Decimal         @default(0) @db.Decimal(14, 2)

  // IPI
  ipiRate         Decimal         @default(0) @db.Decimal(7, 4)
  valueIpi        Decimal         @default(0) @db.Decimal(14, 2)

  // PIS
  pisRate         Decimal         @default(0) @db.Decimal(7, 4)
  valuePis        Decimal         @default(0) @db.Decimal(14, 2)

  // COFINS
  cofinsRate      Decimal         @default(0) @db.Decimal(7, 4)
  valueCofins     Decimal         @default(0) @db.Decimal(14, 2)

  // Crédito PIS/COFINS
  allowsCredit    Boolean         @default(false)

  document        FiscalDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model ClientService {
  id          String            @id @default(cuid())
  clientId    String
  serviceType ClientServiceType
  description String?
  createdAt   DateTime          @default(now())
  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientMonthlyFee {
  id          String                       @id @default(cuid())
  clientId    String
  amount      Decimal                      @db.Decimal(10, 2)
  startDate   DateTime
  status      ContractStatus               @default(ATIVO)
  isCurrent   Boolean                      @default(true)
  createdAt   DateTime                     @default(now())
  client      Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  adjustments ClientMonthlyFeeAdjustment[]
}

model ClientMonthlyFeeAdjustment {
  id             String           @id @default(cuid())
  monthlyFeeId   String
  previousAmount Decimal          @db.Decimal(10, 2)
  newAmount      Decimal          @db.Decimal(10, 2)
  effectiveDate  DateTime
  notes          String?
  createdAt      DateTime         @default(now())
  monthlyFee     ClientMonthlyFee @relation(fields: [monthlyFeeId], references: [id], onDelete: Cascade)
}

model ClientChangeLog {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  fieldName String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model ProcessFlowTemplate {
  id        String                @id @default(cuid())
  name      String
  type      ProcessType
  isDefault Boolean               @default(false)
  createdAt DateTime              @default(now())
  processes Process[]
  steps     ProcessStepTemplate[]
}

model ProcessStepTemplate {
  id         String              @id @default(cuid())
  templateId String
  title      String
  orderIndex Int
  createdAt  DateTime            @default(now())
  template   ProcessFlowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Process {
  id                   String                @id @default(cuid())
  clientId             String
  flowTemplateId       String?
  title                String
  description          String?
  type                 ProcessType
  status               ProcessStatus         @default(ESCRITORIO_EXECUTANDO)
  priority             PriorityLevel         @default(MEDIA)
  responsibleId        String?
  dueDate              DateTime?
  startedAt            DateTime              @default(now())
  completedAt          DateTime?
  notes                String?
  closureEffectiveDate DateTime?
  protocolNumber       String?
  finalNotes           String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  createdById          String
  updatedById          String
  alerts               Alert[]
  documents            Document[]
  client               Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy            User                  @relation("ProcessCreatedBy", fields: [createdById], references: [id])
  flowTemplate         ProcessFlowTemplate?  @relation(fields: [flowTemplateId], references: [id])
  responsible          User?                 @relation("ProcessResponsible", fields: [responsibleId], references: [id])
  updatedBy            User                  @relation("ProcessUpdatedBy", fields: [updatedById], references: [id])
  fee                  ProcessFee?
  movements            ProcessMovement[]
  pendingIssues        ProcessPendingIssue[]
  steps                ProcessStep[]
}

model ProcessStep {
  id             String     @id @default(cuid())
  processId      String
  templateStepId String?
  title          String
  orderIndex     Int
  status         StepStatus @default(PENDENTE)
  responsibleId  String?
  dueDate        DateTime?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  process        Process    @relation(fields: [processId], references: [id], onDelete: Cascade)
  responsible    User?      @relation("StepResponsible", fields: [responsibleId], references: [id])
}

model ProcessMovement {
  id             String         @id @default(cuid())
  processId      String
  userId         String
  description    String
  previousStatus ProcessStatus?
  nextStatus     ProcessStatus?
  createdAt      DateTime       @default(now())
  process        Process        @relation(fields: [processId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id])
}

model ProcessPendingIssue {
  id          String           @id @default(cuid())
  processId   String
  type        PendingIssueType
  description String
  resolved    Boolean          @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  process     Process          @relation(fields: [processId], references: [id], onDelete: Cascade)
}

model ProcessFee {
  id                String               @id @default(cuid())
  processId         String               @unique
  totalAmount       Decimal              @db.Decimal(10, 2)
  paymentMethod     PaymentMethod
  installmentsCount Int                  @default(1)
  paymentStatus     PaymentStatus        @default(PENDENTE)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  process           Process              @relation(fields: [processId], references: [id], onDelete: Cascade)
  installments      ProcessInstallment[]
}

model ProcessInstallment {
  id       String        @id @default(cuid())
  feeId    String
  sequence Int
  dueDate  DateTime
  amount   Decimal       @db.Decimal(10, 2)
  status   PaymentStatus @default(PENDENTE)
  paidAt   DateTime?
  fee      ProcessFee    @relation(fields: [feeId], references: [id], onDelete: Cascade)
}

model Document {
  id           String             @id @default(cuid())
  originalName String
  fileName     String
  storagePath  String
  mimeType     String
  size         Int
  entityType   DocumentEntityType
  clientId     String?
  processId    String?
  uploadedById String
  createdAt    DateTime           @default(now())
  client       Client?            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  process      Process?           @relation(fields: [processId], references: [id], onDelete: Cascade)
  uploadedBy   User               @relation(fields: [uploadedById], references: [id])
}

model TaxAnnualReview {
  id               String          @id @default(cuid())
  clientId         String
  year             Int
  status           TaxReviewStatus
  verificationDate DateTime
  notes            String?
  reviewedById     String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  client           Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reviewedBy       User            @relation(fields: [reviewedById], references: [id])

  @@unique([clientId, year])
}

model Alert {
  id           String        @id @default(cuid())
  type         AlertType
  severity     AlertSeverity
  title        String
  description  String?
  dueDate      DateTime?
  resolved     Boolean       @default(false)
  resolvedAt   DateTime?
  resolvedById String?
  clientId     String?
  processId    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  process      Process?      @relation(fields: [processId], references: [id], onDelete: Cascade)
  resolvedBy   User?         @relation("AlertResolvedBy", fields: [resolvedById], references: [id])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String
  action     AuditAction
  entity     String
  entityId   String
  summary    String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id])
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum CompanyType {
  MEI
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

enum CompanyStatus {
  ATIVA
  SUSPENSA
  INATIVA
  ENCERRADA
}

enum ClientServiceType {
  CONTABILIDADE_REGULAR
  MEI
  FOLHA_DOMESTICA
  ASSESSORIA
  DEPARTAMENTO_PESSOAL
  FISCAL
  IMPOSTO_RENDA
  ABERTURA_EMPRESA
  ALTERACAO_CONTRATUAL
  ENCERRAMENTO_EMPRESA
  OUTROS
}

enum ContractStatus {
  ATIVO
  SUSPENSO
  ENCERRADO
}

enum ProcessType {
  ABERTURA_EMPRESA
