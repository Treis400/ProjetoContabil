  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  client         Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  partAEntries   LalurPartAEntry[]
  accountingRules LalurAccountingRule[]

  @@unique([clientId, code])
}

model LalurPeriod {
  id               String              @id @default(cuid())
  clientId         String
  periodYear       Int
  taxRegime        TaxRegimeCalc       @default(LUCRO_REAL)
  accountingProfit Decimal             @default(0) @db.Decimal(14, 2)
  totalAdditions   Decimal             @default(0) @db.Decimal(14, 2)
  totalExclusions  Decimal             @default(0) @db.Decimal(14, 2)
  totalCompensations Decimal           @default(0) @db.Decimal(14, 2)
  realProfit       Decimal             @default(0) @db.Decimal(14, 2)
  status           IrpjCsllCalcStatus  @default(RASCUNHO)
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  lockedAt         DateTime?
  lockedByUserId   String?

  client           Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lockedBy         User?               @relation("LalurPeriodLockedBy", fields: [lockedByUserId], references: [id])
  partAEntries     LalurPartAEntry[]
  partBBalances    LalurPartBBalance[]
  irpjCsllCalc     IrpjCsllCalc?
  compensations    LalurCompensation[]
  accountingImports LalurAccountingImport[]

  @@unique([clientId, periodYear])
}

model LalurPartAEntry {
  id              String            @id @default(cuid())
  lalurPeriodId   String
  adjustTypeId    String?
  sequence        Int
  description     String
  nature          LalurAdjustNature
  timing          LalurAdjustTiming @default(PERMANENTE)
  value           Decimal           @db.Decimal(14, 2)
  accountCode     String?
  documentRef     String?
  notes           String?
  periodMonth     Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  lalurPeriod     LalurPeriod       @relation(fields: [lalurPeriodId], references: [id], onDelete: Cascade)
  adjustType      LalurAdjustType?  @relation(fields: [adjustTypeId], references: [id])
  partBEntries    LalurPartBBalance[]

  @@index([lalurPeriodId])
}

model LalurPartBBalance {
  id              String                  @id @default(cuid())
  lalurPeriodId   String
  partAEntryId    String?
  description     String
  type            LalurPartBType
  controlType     LalurPartBControlType   @default(AJUSTE_TEMPORARIO)
  originDate      DateTime?
  originalValue   Decimal?                @db.Decimal(14, 2)
  usedValue       Decimal                 @default(0) @db.Decimal(14, 2)
  openingBalance  Decimal                 @default(0) @db.Decimal(14, 2)
  additions       Decimal                 @default(0) @db.Decimal(14, 2)
  realizations    Decimal                 @default(0) @db.Decimal(14, 2)
  closingBalance  Decimal                 @default(0) @db.Decimal(14, 2)
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  lalurPeriod     LalurPeriod             @relation(fields: [lalurPeriodId], references: [id], onDelete: Cascade)
  partAEntry      LalurPartAEntry?        @relation(fields: [partAEntryId], references: [id])
  movements       LalurPartBMovement[]

  @@index([lalurPeriodId])
}

model IrpjCsllCalc {
  id                    String              @id @default(cuid())
  lalurPeriodId         String              @unique
  taxRegime             TaxRegimeCalc       @default(LUCRO_REAL)

  // Base de cálculo
  irpjBase              Decimal             @default(0) @db.Decimal(14, 2)
  csllBase              Decimal             @default(0) @db.Decimal(14, 2)

  // IRPJ
  irpjRate              Decimal             @default(15) @db.Decimal(7, 4)
  irpjValue             Decimal             @default(0) @db.Decimal(14, 2)
  irpjSurchargeBase     Decimal             @default(0) @db.Decimal(14, 2)
  irpjSurchargeRate     Decimal             @default(10) @db.Decimal(7, 4)
  irpjSurchargeValue    Decimal             @default(0) @db.Decimal(14, 2)
  irpjTotal             Decimal             @default(0) @db.Decimal(14, 2)

  // CSLL
  csllRate              Decimal             @default(9) @db.Decimal(7, 4)
  csllValue             Decimal             @default(0) @db.Decimal(14, 2)

  // Deduções / incentivos
  irpjIncentives        Decimal             @default(0) @db.Decimal(14, 2)
  csllIncentives        Decimal             @default(0) @db.Decimal(14, 2)

  // Net
  irpjNet               Decimal             @default(0) @db.Decimal(14, 2)
  csllNet               Decimal             @default(0) @db.Decimal(14, 2)

  // CSLL estimativa mensal acumulada
  irpjMonthlyEstimate   Decimal             @default(0) @db.Decimal(14, 2)
  csllMonthlyEstimate   Decimal             @default(0) @db.Decimal(14, 2)

  status                IrpjCsllCalcStatus  @default(RASCUNHO)
  calculatedAt          DateTime?
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  lalurPeriod           LalurPeriod         @relation(fields: [lalurPeriodId], references: [id], onDelete: Cascade)
}

model EcfFile {
