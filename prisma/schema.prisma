model AccountingPlan {
  id                   String           @id @default(cuid())
  clientId             String
  code                 String
  name                 String
  type                 AccountType      @default(ANALITICA)
  nature               AccountNature
  classification       AccountClass
  level                Int              @default(1)
  parentId             String?
  allowsEntry          Boolean          @default(true)
  usesCostCenter       Boolean          @default(false)
  usesStdHistory       Boolean          @default(false)
  integratesModules    Boolean          @default(false)
  spedRefCode          String?
  ecfRefCode           String?
  notes                String?
  active               Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  client               Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent               AccountingPlan?  @relation("AccountParent", fields: [parentId], references: [id])
  children             AccountingPlan[] @relation("AccountParent")

  @@unique([clientId, code])
  @@index([clientId, level])
  @@index([clientId, classification])
}

model CostCenter {
  id        String         @id @default(cuid())
  clientId  String
  code      String
  name      String
  type      CostCenterType @default(OPERACIONAL)
  level     Int            @default(1)
  parentId  String?
  required  Boolean        @default(false)
  active    Boolean        @default(true)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent    CostCenter?    @relation("CostCenterParent", fields: [parentId], references: [id])
  children  CostCenter[]   @relation("CostCenterParent")

  @@unique([clientId, code])
  @@index([clientId, level])
}

model StandardHistory {
  id         String   @id @default(cuid())
  clientId   String
